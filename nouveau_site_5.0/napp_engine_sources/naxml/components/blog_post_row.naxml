<blog_post_row_cardline data-tags="{tags}">
    <column>
        <row>
            <title name_en="{title_en}" name_fr="{title_fr}" />
            <text> - </text>
            <date>{date}</date>
        </row>
        <text name_en="{summary_en}" name_fr="{summary_fr}" />
    </column>

    <center>
        <button_action icon="read" name_en="Read Article" name_fr="Lire l'article" action="navigate" url="pages/blog/entry_{_source_file}.html" />
    </center>
</blog_post_row_cardline>
