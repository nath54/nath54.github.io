<main_container>
    <single_column>
        <title_text name_en="The Museum" name_fr="Le musée" />
        <text
            name_en="Choose a gallery to visit."
            name_fr="Choisissez une galerie à visiter."
        />

        <categories_grid>
            <exec_generate
                parser="yaml_directory"
                source="data/media"
                template="museum_category_card"
                mode="unique_types"
                type_field="media_type"
            />
        </categories_grid>
    </single_column>
</main_container>
