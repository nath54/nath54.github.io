<main_container>
    <single_column>
        <title_text name_en="My Projects" name_fr="Mes projets" />

        <filter_bar>
            <search_input placeholder="Search projects..." />
            <filter_group>
                <filter_button active="true" data-filter="all" name_en="All" name_fr="Tous" />
                <filter_button data-filter="personal" name_en="Personal" name_fr="Personnel" />
                <filter_button data-filter="academic" name_en="Academic" name_fr="Académique" />
                <filter_button data-filter="professional" name_en="Professional" name_fr="Professionnel" />
            </filter_group>
        </filter_bar>

        <projects_grid>
            <exec_generate
                parser="yaml_directory"
                source="data/projects/"
                template="project_card"
                filter="project_showcase_importance >= 40"
                sort_by="project_showcase_importance"
                sort_order="desc"
            />
        </projects_grid>

        <modals_container>
            <exec_generate
                parser="yaml_directory"
                source="data/projects/"
                template="project_modal"
                filter="project_showcase_importance >= 40"
                sort_by="project_showcase_importance"
                sort_order="desc"
            />
        </modals_container>
    </single_column>
</main_container>
