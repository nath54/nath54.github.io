<main_container>
    <single_column>
        <title_text name_en="Blog" name_fr="Blog" />
        <text
            name_en="Where I drop my thoughts in a not very organized way."
            name_fr="Où je dépose mes pensées de manière pas très organisée."
        />

        <blog_pages_container>
            <exec_generate
                parser="yaml_directory"
                source="data/blogs"
                template="blog_post_row"
                sort_by="date"
                sort_order="desc"
                paginate="25"
            />
        </blog_pages_container>
    </single_column>
</main_container>
