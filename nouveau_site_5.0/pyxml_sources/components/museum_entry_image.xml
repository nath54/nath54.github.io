<main_container>
    <single_column>
        <media_header>
            <title_text>{title_en}</title_text>
            <date_text>{date}</date_text>
        </media_header>

        <media_content data-type="image">
            <image_full src="{image_url}" alt="{title_en}" />
        </media_content>

        <media_description
            data-translation-en="{description_en}"
            data-translation-fr="{description_fr}"
        >{description_en}</media_description>
    </single_column>
</main_container>
