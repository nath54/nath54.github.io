<main_container>
    <single_column>
        <article_header>
            <article_cover src="{cover_image}" />
            <title_text name_en="{title_en}" name_fr="{title_fr}" />
            <article_metadata>
                <date>{date}</date>
                <author>{author}</author>
                <tags_list>
                    <exec_foreach var="tag" in="{tags}">
                        <tag>{tag}</tag>
                    </exec_foreach>
                </tags_list>
            </article_metadata>
        </article_header>

        <article_body>
            <markdown_render
                name_en="{markdown_content_en_html}"
                name_fr="{markdown_content_fr_html}"
            />
        </article_body>

        <article_footer>
            <button_action icon="back" name_en="Back to Blog" name_fr="Retour au blog" action="navigate" url="pages/blog.html" />
        </article_footer>
    </single_column>
</main_container>
