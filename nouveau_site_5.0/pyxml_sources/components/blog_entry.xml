<main_container>
    <single_column>
        <article_header>
            <article_cover src="{cover_image}" />
            <title_text
                data-translation-en="{title_en}"
                data-translation-fr="{title_fr}"
            >{title_en}</title_text>
            <article_metadata>
                <date>{date}</date>
                <author>{author}</author>
                <tags_list>
                    <exec_foreach var="tag" in="{tags}">
                        <tag>{tag}</tag>
                    </exec_foreach>
                </tags_list>
            </article_metadata>
        </article_header>

        <article_body>
            <markdown_render
                data-translation-en="{markdown_content_en_html}"
                data-translation-fr="{markdown_content_fr_html}"
            >
                {markdown_content_en_html}
            </markdown_render>
        </article_body>

        <article_footer>
            <button_action icon="back" name="Back to Blog" action="navigate" url="pages/blog.html" />
        </article_footer>
    </single_column>
</main_container>
