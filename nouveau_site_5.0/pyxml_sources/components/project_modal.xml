<project_modal id="modal_project_{_source_file}" class="hidden">
    <modal_header>
        <title>{name_en}</title>
        <button_close target="modal_project_{_source_file}" />
    </modal_header>
    <modal_body>
        <long_description
            data-translation-en="{description_en}"
            data-translation-fr="{description_fr}"
        >{description_en}</long_description>

        <image_carousel>
            <exec_foreach var="img" in="{gallery}">
                <img src="{img}" />
            </exec_foreach>
        </image_carousel>

        <todo_list>
            <exec_foreach var="todo" in="{TODOLIST}">
                <todo_item data-checked="{todo[checked]}">{todo[name]}</todo_item>
            </exec_foreach>
        </todo_list>
    </modal_body>
</project_modal>
