        <media_header>
            <title_text name_en="{title_en}" name_fr="{title_fr}" />
            <date_text>{date}</date_text>
        </media_header>

        <media_content data-type="text">
            <text_scrollable name_en="{text_content_en}" name_fr="{text_content_fr}" />
